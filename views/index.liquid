{% render 'views/head.liquid' %}

<header>
    <form id="searchbar-form" action="/zoeken" method="GET">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-search-icon lucide-search"><path d="m21 21-4.34-4.34"/><circle cx="11" cy="11" r="8"/></svg>
        <input type="search" id="searchbar" name="search" placeholder="Search for Pokémon.." autocomplete="off">
    </form>
</header>

<main>
    <section class="heading-filter-container">
        <h1>All Pokémon</h1>

        <details>
            <summary>Filter by type <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-chevron-down-icon lucide-chevron-down"><path d="m6 9 6 6 6-6"/></svg></summary>
            <div class="filter-dropdown" id="filter-dropdown">
            <p>Filter by type</p>
                <ul>
                    <li><a href="/?type=fire">Fire</a></li>
                    <li><a href="/?type=water">Water</a></li>
                    <li><a href="/?type=grass">Grass</a></li>
                    <li><a href="/?type=poison">Poison</a></li>
                    <li><a href="/?type=electric">Electric</a></li>
                    <li><a href="/?type=psychic">Psychic</a></li>
                    <li><a href="/?type=normal">Normal</a></li>
                    <li><a href="/?type=fighting">Fighting</a></li>
                    <li><a href="/?type=rock">Rock</a></li>
                    <li><a href="/?type=ground">Ground</a></li>
                    <li><a href="/?type=ice">Ice</a></li>
                    <li><a href="/?type=bug">Bug</a></li>
                    <li><a href="/?type=ghost">Ghost</a></li>
                    <li><a href="/?type=dragon">Dragon</a></li>
                    <li><a href="/?type=dark">Dark</a></li>
                    <li><a href="/?type=steel">Steel</a></li>
                    <li><a href="/?type=fairy">Fairy</a></li>
                    <li><a href="/?type=flying">Flying</a></li>
                </ul>
            </div>
        </details>
    </section>

    <section class="pokemon-cards-container">
        {% for pokemon in pokemons %}
            <a href="/pokemon/{{ pokemon.id }}">
                <article class="pokemon-card">
                    <div>00{{ pokemon.id }}</div>
                    <img src="{{ pokemon.image }}" alt="{{ pokemon.name }}">
                    <div class="pokemon-name-container">
                        <span>{{ pokemon.name | capitalize }}</span>
                        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-ellipsis-vertical-icon lucide-ellipsis-vertical"><circle cx="12" cy="12" r="1"/><circle cx="12" cy="5" r="1"/><circle cx="12" cy="19" r="1"/></svg>
                    </div>
                </article>
            </a>
        {% endfor %}
    </section>

    <nav class="pagination">
        {% if page > 1 %}
            <a href="/?page={{ page | minus: 1 }}">Vorige</a>
        {% endif %}

        <span>{{ page }} / {{ totalPages }}</span>

        {% if page < totalPages %}
            <a href="/?page={{ page | plus: 1 }}">Volgende</a>
        {% endif %}
    </nav>
</main>

<footer>
    <nav>
        <a href="/" class="active">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><circle cx="12" cy="12" r="3" fill="white" stroke="currentColor"/></svg>
            <p>Pokémons</p>
        </a>

        <a href="/favorites">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-heart-icon lucide-heart"><path d="M2 9.5a5.5 5.5 0 0 1 9.591-3.676.56.56 0 0 0 .818 0A5.49 5.49 0 0 1 22 9.5c0 2.29-1.5 4-3 5.5l-5.492 5.313a2 2 0 0 1-3 .019L5 15c-1.5-1.5-3-3.2-3-5.5"/></svg>
            <p>Favorites</p>
        </a>
    </nav>
</footer>

{% render 'views/foot.liquid' %}